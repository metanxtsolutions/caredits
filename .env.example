# Database (Postgres — see docker-compose.yml for a local instance)
DATABASE_URL="postgresql://caredits:caredits@localhost:5432/caredits"

# Site
NEXT_PUBLIC_SITE_URL="https://careditskolkata.com"

# Razorpay (payments)
# Leave unset to run the booking flow in sandbox mode (simulated payments).
# Add real keys to go live — see src/lib/payments/razorpay.ts.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# Stripe (optional alternative payment provider — architecture only, not yet wired up)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""

# SMS / WhatsApp / Email notifications
# Leave unset to run in sandbox mode (logs to the console instead of sending) — see
# src/lib/notifications/. Twilio (SMS + WhatsApp Business API):
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_SMS_FROM=""
TWILIO_WHATSAPP_FROM=""

# SMTP (booking confirmation emails)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="hello@careditskolkata.com"

# Session signing (phone/OTP login — see src/lib/auth.ts) + Google OAuth
# (see src/lib/google-auth.ts). Leave the Google vars unset to hide that login option.
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
