# Database
# Local dev uses SQLite out of the box — no setup required.
# For production, switch prisma/schema.prisma datasource provider to "postgresql"
# and point this at your Postgres instance.
DATABASE_URL="file:./dev.db"

# Site
NEXT_PUBLIC_SITE_URL="https://careditskolkata.com"

# Razorpay (payments)
# Leave unset to run the booking flow in sandbox mode (simulated payments).
# Add real keys to go live — see src/lib/payments/razorpay.ts.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# Stripe (optional alternative payment provider — architecture only, not yet wired up)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""

# SMS / WhatsApp / Email notifications (architecture only — not yet wired up)
# Twilio (SMS + WhatsApp Business API)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM=""

# SMTP (booking confirmation emails)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="hello@careditskolkata.com"

# NextAuth (Phase 2 — OTP / Google login)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
